{
  "name": "pi-dungeon",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "description": "Dungeon sandbox extension for pi — runs agent tools inside a micro-VM",
  "license": "MIT",
  "author": "Jonas Damtoft",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jomik/pi-dungeon.git"
  },
  "type": "module",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0"
  },
  "dependencies": {
    "@earendil-works/gondolin": "^0.9.0",
    "typebox": "^1.1.0"
  },
  "scripts": {
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "check:schema": "node scripts/generate-schema.ts && git diff --exit-code dungeon.schema.json",
    "build": "npx gondolin build --config build-config.json --output ./image",
    "test": "vitest run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
