{
  "name": "pi-gondolin",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "description": "Gondolin sandbox extension for pi — runs agent tools inside a micro-VM",
  "type": "module",
  "pi": {
    "extensions": [
      "./extension.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0"
  },
  "dependencies": {
    "@earendil-works/gondolin": "^0.9.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npx gondolin build --config build-config.json --output ./image",
    "test": "vitest run"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
