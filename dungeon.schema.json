{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jomik/pi-dungeon/dungeon.schema.json",
  "title": "Dungeon Config",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "allowedHosts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "secrets": {
      "type": "object",
      "patternProperties": {
        "^.*$": {
          "type": "object",
          "required": [
            "keychain",
            "hosts"
          ],
          "properties": {
            "keychain": {
              "type": "string"
            },
            "hosts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "mounts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hiddenPaths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tmpfsPaths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "env": {
      "type": "object",
      "patternProperties": {
        "^.*$": {
          "type": "string"
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "memory": {
          "type": "string"
        },
        "cpus": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  },
  "additionalProperties": false
}
